                            <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" id="reg-btn-rg">
                                <rect key="frame" x="20" y="390" width="335" height="44"/>
